# Satellite + 3D terrain (client-visible public map key)
VITE_MAPTILER_KEY=

# Supabase public browser connection
VITE_BACKEND_MODE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional compatibility with old projects:
VITE_SUPABASE_ANON_KEY=

# Routing service. For production, use your own compatible endpoint.
VITE_ROUTING_BASE_URL=https://router.project-osrm.org

# Later Hostinger/MySQL migration: browser talks to an API, never directly to MySQL.
VITE_MYSQL_API_BASE_URL=

VITE_MAP_DATA_VERSION=2026-07-23-qalla-wanan-r12-compact-large-rtl
